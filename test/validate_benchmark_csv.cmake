if(NOT DEFINED CSV_PATH)
    message(FATAL_ERROR "CSV_PATH is not provided")
endif()

if(NOT EXISTS "${CSV_PATH}")
    message(FATAL_ERROR "Benchmark CSV does not exist: ${CSV_PATH}")
endif()

file(READ "${CSV_PATH}" CSV_CONTENT)

if(CSV_CONTENT STREQUAL "")
    message(FATAL_ERROR "Benchmark CSV is empty: ${CSV_PATH}")
endif()

string(REPLACE "\r\n" "\n" CSV_CONTENT "${CSV_CONTENT}")
string(REPLACE "\r" "\n" CSV_CONTENT "${CSV_CONTENT}")
string(REGEX MATCH "^[^\n]*" CSV_HEADER "${CSV_CONTENT}")

if(NOT CSV_HEADER MATCHES "runIndex")
    message(FATAL_ERROR "CSV header missing runIndex column")
endif()
if(NOT CSV_HEADER MATCHES "sceneIndex")
    message(FATAL_ERROR "CSV header missing sceneIndex column")
endif()
if(NOT CSV_HEADER MATCHES "stepIndex")
    message(FATAL_ERROR "CSV header missing stepIndex column")
endif()
if(NOT CSV_HEADER MATCHES "globalCorrectionEnabled")
    message(FATAL_ERROR "CSV header missing globalCorrectionEnabled column")
endif()
if(NOT CSV_HEADER MATCHES "globalCorrectionIterations")
    message(FATAL_ERROR "CSV header missing globalCorrectionIterations column")
endif()
if(NOT CSV_HEADER MATCHES "maxJointResidual")
    message(FATAL_ERROR "CSV header missing maxJointResidual column")
endif()
if(NOT CSV_HEADER MATCHES "maxPenetration")
    message(FATAL_ERROR "CSV header missing maxPenetration column")
endif()
if(NOT CSV_HEADER MATCHES "maxJointForce")
    message(FATAL_ERROR "CSV header missing maxJointForce column")
endif()
if(NOT CSV_HEADER MATCHES "maxJointTorque")
    message(FATAL_ERROR "CSV header missing maxJointTorque column")
endif()
if(NOT CSV_HEADER MATCHES "maxContactNormalForce")
    message(FATAL_ERROR "CSV header missing maxContactNormalForce column")
endif()
if(NOT CSV_HEADER MATCHES "avgContactTangentialForce")
    message(FATAL_ERROR "CSV header missing avgContactTangentialForce column")
endif()
if(NOT CSV_HEADER MATCHES "stickingContacts")
    message(FATAL_ERROR "CSV header missing stickingContacts column")
endif()
if(NOT CSV_HEADER MATCHES "totalEnergy")
    message(FATAL_ERROR "CSV header missing totalEnergy column")
endif()

string(REGEX MATCHALL "\n" CSV_NEWLINES "${CSV_CONTENT}")
list(LENGTH CSV_NEWLINES CSV_LINEBREAK_COUNT)

if(CSV_LINEBREAK_COUNT LESS 2)
    message(FATAL_ERROR "Benchmark CSV should contain header plus at least one data line")
endif()

message(STATUS "Validated benchmark CSV: ${CSV_PATH}")
